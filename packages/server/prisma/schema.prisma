generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id                Int      @id @default(autoincrement())
  name              String
  username          String   @unique
  password          String
  telegramId        String?  @unique
  canManageAccounts Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Bot {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  name      String
  username  String?
  isActive  Boolean  @default(true)
  // 全局 URL 按钮:在每条常规资源(链接派发/随便看看/收藏列表)的内容键盘里追加,
  // 位置在资源自己的 URL 按钮之后、「🔽 展开更多」之前。结构 [{text, url}, ...]
  globalButtons Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inviteLinks      InviteLink[]
  fileIds          BotFileId[]
  botUsers         BotUser[]
  channelGroups    ResourceGroup[]      @relation("ChannelGroupSourceBot")
  subscriptionGate BotSubscriptionGate?
  // 自动同步:本 bot 是同步发起方(每天 0 点从 target 拉同名链接的资源内容)
  autoSyncConfig         BotAutoSyncConfig?  @relation("AutoSyncOwner")
  // 自动同步:其他 bot 引用本 bot 作为同步目标
  autoSyncTargetedBy     BotAutoSyncConfig[] @relation("AutoSyncTarget")
}

/**
 * 每个 bot 的自动同步配置(一对一)。
 * 启用后,每天凌晨 00:00 比对 botId 与 targetBotId 的 InviteLink (按 name 同名匹配),
 * 把目标 bot 这条链接下的 ContentBinding (仅 resourceId + sortOrder, 不含 buttons)
 * 完全覆盖到本 bot 这条链接。订阅频道/赞助商/按钮均不同步。
 */
model BotAutoSyncConfig {
  id              Int      @id @default(autoincrement())
  botId           Int      @unique
  enabled         Boolean  @default(false)
  targetBotId     Int?
  lastSyncAt      DateTime?
  lastSyncStatus  String?   // 'success' | 'failed' | 'partial'
  lastSyncMessage String?   // 概要,例如 "同步 5 链接 / 89 资源"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bot       Bot  @relation("AutoSyncOwner", fields: [botId], references: [id], onDelete: Cascade)
  targetBot Bot? @relation("AutoSyncTarget", fields: [targetBotId], references: [id], onDelete: SetNull)
}

model InviteLink {
  id        Int      @id @default(autoincrement())
  botId     Int
  code      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bot              Bot               @relation(fields: [botId], references: [id], onDelete: Cascade)
  contentBindings  ContentBinding[]
  adBindings       AdBinding[]
  botUsers         BotUser[]
  subscriptionGate SubscriptionGate?

  @@unique([botId, code])
}

model ResourceGroup {
  id            Int        @id @default(autoincrement())
  name          String
  sortOrder     Int        @default(0)
  // 频道激活来源(null = 后台手动创建)
  channelChatId BigInt?    @unique
  channelTitle  String?
  sourceBotId   Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  resources Resource[]
  sourceBot Bot?       @relation("ChannelGroupSourceBot", fields: [sourceBotId], references: [id], onDelete: SetNull)
}

model Resource {
  id        Int      @id @default(autoincrement())
  groupId   Int?
  type      String
  caption   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group           ResourceGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  mediaFiles      MediaFile[]
  contentBindings ContentBinding[]
  adBindings      AdBinding[]
  tags            ResourceTag[]
  favorites       FavoriteResource[]
}

model ResourceTag {
  id         Int      @id @default(autoincrement())
  resourceId Int
  tag        String
  createdAt  DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, tag])
  @@index([tag])
}

model FavoriteResource {
  id         Int      @id @default(autoincrement())
  botUserId  Int
  resourceId Int
  createdAt  DateTime @default(now())

  botUser  BotUser  @relation(fields: [botUserId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([botUserId, resourceId])
  @@index([resourceId])
}

model MediaFile {
  id            Int      @id @default(autoincrement())
  resourceId    Int
  type          String
  filePath      String
  fileName      String
  mimeType      String
  fileSize      Int
  duration      Int?
  width         Int?
  height        Int?
  thumbnailPath String?
  sortOrder     Int      @default(0)
  isHidden      Boolean  @default(false)
  // 频道入库时:filePath 预占位为 's3:...' 后台异步上传 Wasabi。
  // 成功时 null;失败时记录错误信息以便后台"上传异常列表"页面查看 + 重试。
  uploadError   String?
  createdAt     DateTime @default(now())

  resource   Resource    @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  botFileIds BotFileId[]

  @@index([uploadError])
}

model BotFileId {
  id          Int    @id @default(autoincrement())
  botId       Int
  mediaFileId Int
  fileId      String

  bot       Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  mediaFile MediaFile @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)

  @@unique([botId, mediaFileId])
}

model ContentBinding {
  id           Int  @id @default(autoincrement())
  inviteLinkId Int
  resourceId   Int
  sortOrder    Int  @default(0)
  buttons      Json?

  inviteLink InviteLink @relation(fields: [inviteLinkId], references: [id], onDelete: Cascade)
  resource   Resource   @relation(fields: [resourceId], references: [id], onDelete: Restrict)
}

model AdBinding {
  id           Int    @id @default(autoincrement())
  inviteLinkId Int
  resourceId   Int
  sortOrder    Int    @default(0)
  buttons      Json?

  inviteLink InviteLink @relation(fields: [inviteLinkId], references: [id], onDelete: Cascade)
  resource   Resource   @relation(fields: [resourceId], references: [id], onDelete: Restrict)
}

model BotUser {
  id           Int      @id @default(autoincrement())
  telegramId   BigInt
  botId        Int
  inviteLinkId Int
  firstName    String?
  lastName     String?
  username     String?
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  bot        Bot          @relation(fields: [botId], references: [id], onDelete: Cascade)
  inviteLink InviteLink   @relation(fields: [inviteLinkId], references: [id], onDelete: Cascade)
  sessions   UserSession[]
  favorites  FavoriteResource[]

  @@unique([telegramId, botId])
}

model UserSession {
  id           Int      @id @default(autoincrement())
  botUserId    Int
  currentIndex Int      @default(0)
  isCompleted  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  mode         String   @default("link")
  payload      Json?

  botUser BotUser @relation(fields: [botUserId], references: [id], onDelete: Cascade)
}

model AdImpression {
  id           Int      @id @default(autoincrement())
  botId        Int
  inviteLinkId Int
  adBindingId  Int
  telegramId   BigInt
  viewedAt     DateTime @default(now())
}

model ButtonClick {
  id           Int      @id @default(autoincrement())
  botId        Int
  inviteLinkId Int
  botUserId    Int
  buttonType   String   // 'next' | 'reveal'
  latencyMs    Int      // 处理延迟(从收到 callback 到返回的 ms)
  clickedAt    DateTime @default(now())

  @@index([inviteLinkId, clickedAt])
  @@index([botUserId, inviteLinkId, buttonType])
  @@index([buttonType, clickedAt])
}

model SystemSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value Json
}

model SubscriptionGate {
  id               Int      @id @default(autoincrement())
  inviteLinkId     Int      @unique
  isEnabled        Boolean  @default(false)
  promptTemplate   String?
  sponsorPositions Int[]    @default([])  // 赞助商触发位置(1-based),与 sponsor channels 按 sortOrder 配对
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  inviteLink InviteLink                @relation(fields: [inviteLinkId], references: [id], onDelete: Cascade)
  channels   SubscriptionGateChannel[]
}

model SubscriptionGateChannel {
  id          Int      @id @default(autoincrement())
  gateId      Int?
  botGateId   Int?
  kind        String   @default("primary")  // "primary" | "sponsor"
  isPrivate   Boolean  @default(false)
  username    String?  // 私有频道无 username
  chatId      BigInt
  title       String
  inviteUrl   String
  sortOrder   Int      @default(0)
  status      String   @default("ok")
  lastCheckAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gate    SubscriptionGate?    @relation(fields: [gateId], references: [id], onDelete: Cascade)
  botGate BotSubscriptionGate? @relation(fields: [botGateId], references: [id], onDelete: Cascade)

  @@unique([gateId, chatId])
}

model SubscriptionCheckPass {
  id          Int      @id @default(autoincrement())
  botId       Int
  telegramId  BigInt
  passDate    String
  passedAt    DateTime @default(now())

  @@unique([botId, telegramId, passDate])
  @@index([passDate])
}

model BotSubscriptionGate {
  id               Int      @id @default(autoincrement())
  botId            Int      @unique
  isEnabled        Boolean  @default(false)
  promptTemplate   String?
  sponsorPositions Int[]    @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bot      Bot                       @relation(fields: [botId], references: [id], onDelete: Cascade)
  channels SubscriptionGateChannel[]
}
